{
    colors: {
        white: '#FFFFFF',
        red: '#FF0000',
        brown: '#A52A2A',
        black: '#000000',
        blue: '#0000FF',        grey: '#808080',

        green: '#00FF00',        yellow: '#FFFF00',

        cyan: '#00FFFF',
        magenta: '#FF00FF',
        orange: '#FFA500',
        purple: '#800080'
    },
    bounds: {x: 0, y: 0, width: 24, height: 24},
    shapes: [
        // Diamond with STRAIGHT segments
        {
            fillColor: red,
            lineColor: white,
            path: [
                {curve: straight, x: 0, y: 4},
                {curve: straight, x: 4, y: 0},
                {curve: straight, x: 8, y: 4},
                {curve: straight, x: 4, y: 8}
            ]
        },
        // Circle with LEFT curves
        {
            fillColor: red,
            lineColor: yellow,
            path: [
                {curve: left, x: 8, y: 4},
                {curve: left, x: 12, y: 0},
                {curve: left, x: 16, y: 4},
                {curve: left, x: 12, y: 8}
            ]
        },
        // Circle with LEFT curves
        {
            fillColor: red,
            lineColor: yellow,
            path: [
                {curve: right, x: 16, y: 4},
                {curve: right, x: 20, y: 0},
                {curve: right, x: 24, y: 4},
                {curve: right, x: 20, y: 8}
            ]
        },
        // Circle with LEFT curves
        {
            fillColor: white,
            lineColor: yellow,
            path: [
                {x: 16, y: 12},
                {x: 20, y: 8},
                {x: 24, y: 12},
                {x: 20, y: 16}
            ]
        }
    ]
}
